{
    "name": "yafet/amharic-datepicker",
    "description": "A modern Ethiopian (Amharic) calendar datepicker for Laravel 12/13.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "yafet",
            "email": "yafetbabi@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Yafet\\AmharicDatepicker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yafet\\AmharicDatepicker\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yafet\\AmharicDatepicker\\AmharicDatepickerServiceProvider"
            ]
        }
    }
}